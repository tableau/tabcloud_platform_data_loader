  <aliases enabled='yes' />
  <column caption='Item LUID' datatype='string' name='[Calculation_1166713787199430659]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [Calculation_1166713788613742607]:    &#13;&#10;    MAX(LOWER([objLuid]))&#13;&#10;}' />
    <desc>
      <formatted-text>
        <run>The LUID of the item. The LUID is unique within each item type and site. Primarily used to reference content via the REST API.</run>
      </formatted-text>
    </desc>
  </column>
  <column caption='Job LUID' datatype='string' name='[Calculation_1166713788613742607]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='LOWER([jobLuid])' />
  </column>
  <column caption='Obj Type (impute from args)' datatype='string' name='[Calculation_1396678843169206273]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='IF ISNULL([objType]) AND NOT ISNULL([args]) &#13;&#10;THEN&#13;&#10;    IF [jobType] = &apos;CreateExtracts&apos;&#13;&#10;        OR [jobType] = &apos;EncryptExtracts&apos;&#13;&#10;        OR [jobType] = &apos;EnqueueDataAlerts&apos;&#13;&#10;        OR [jobType] = &apos;MaterializeViews&apos;&#13;&#10;        OR [jobType] = &apos;RefreshExtracts&apos;&#13;&#10;    THEN REPLACE(&#13;&#10;            SPLIT([args], &apos;,&apos;,1),&#13;&#10;            &apos;[&apos;,&#13;&#10;            &apos;&apos;&#13;&#10;         )        &#13;&#10;        ELSE NULL&#13;&#10;    END&#13;&#10;ELSE NULL&#13;&#10;END' />
  </column>
  <column caption='Last Record Date' datatype='datetime' name='[Calculation_1763159319831965698]' role='dimension' type='ordinal'>
    <calculation class='tableau' formula='{ MAX([eventTime]) } // Fixed LOD to find the last date value in the entire data set' />
  </column>
  <column caption='Job Queued At' datatype='datetime' name='[Calculation_1867023573835550723]' role='dimension' type='ordinal'>
    <calculation class='tableau' formula='{ FIXED [Calculation_1166713788613742607]:&#13;&#10;&#13;&#10;    MAX( // double maxing is because passing multiple arguments to MAX makes it &quot;not an aggregate&quot; - dumb!&#13;&#10;        MAX( &#13;&#10;            (IF CONTAINS(LOWER([eventState]), &apos;queued&apos;) THEN [eventTime] ELSE NULL END),&#13;&#10;            [Job Completed At (copy)_1763159319825977345] // it if wasn&apos;t queued, then the created time is the queued time&#13;&#10;        )&#13;&#10;    )&#13;&#10;}' />
  </column>
  <column caption='Job Queued Duration (s)' datatype='integer' name='[Calculation_1867023573837676551]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='IFNULL(DATEDIFF(&apos;second&apos;, [Calculation_1867023573835550723], IFNULL([Job Created Time (copy)_1867023573836746757], [Calculation_1763159319831965698])), 0)' />
  </column>
  <column caption='Item LUID Is NULL' datatype='boolean' name='[Calculation_2288391620038856704]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='ISNULL([objLuid])' />
  </column>
  <column caption='Is Last Job Record' datatype='boolean' name='[Event State (copy) (copy)_1867023574713860105]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [Calculation_1166713788613742607]:&#13;&#10;&#13;&#10;MAX([eventTime])&#13;&#10;&#13;&#10;} = [eventTime]' />
  </column>
  <column caption='Last Job State' datatype='string' name='[Event State (copy)_1867023574713659400]' role='dimension' semantic-role='' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [Calculation_1166713788613742607]:&#13;&#10;&#13;&#10;MAX(IF [Event State (copy) (copy)_1867023574713860105] THEN [eventState] ELSE NULL END)&#13;&#10;&#13;&#10;}' />
  </column>
  <column caption='Event State' datatype='string' name='[Event State (copy)_2288391620445376515]' role='dimension' semantic-role='' type='nominal'>
    <calculation class='tableau' formula='IF CONTAINS(LOWER([eventState]), &apos;failed&apos;)&#13;&#10;    THEN &apos;Failed&apos;&#13;&#10;ELSEIF CONTAINS(LOWER([eventState]), &apos;success&apos;)&#13;&#10;    THEN &apos;Success&apos;&#13;&#10;ELSEIF CONTAINS(LOWER([eventState]), &apos;queued&apos;)&#13;&#10;    THEN &apos;Queued&apos;&#13;&#10;ELSEIF CONTAINS(LOWER([eventState]), &apos;promoted&apos;)&#13;&#10;    THEN &apos;Promoted&apos;&#13;&#10;ELSEIF CONTAINS(LOWER([eventState]), &apos;started&apos;)&#13;&#10;    THEN &apos;Started&apos;&#13;&#10;ELSE &apos;Unknown&apos;&#13;&#10;END' />
  </column>
  <column caption='Is First Job Record' datatype='boolean' name='[Is Last Job Record (copy)_1763159319825780736]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [Calculation_1166713788613742607]:&#13;&#10;&#13;&#10;    MIN([eventTime])&#13;&#10;&#13;&#10;} = [eventTime]' />
  </column>
  <column caption='Item Name  Is NULL' datatype='boolean' name='[Item LUID Is NULL (copy)_2288391620039077889]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='ISNULL([objName])' />
  </column>
  <column caption='Item Name' datatype='string' name='[Item Luid (copy)_1166713787200434180]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [jobLuid]:&#13;&#10;    MAX(&#13;&#10;        IFNULL(&#13;&#10;            [objName], &#13;&#10;            [Obj Type (impute from args) (copy)_1166713787198435329])&#13;&#10;        )&#13;&#10;}' />
    <desc>
      <formatted-text>
        <run>For data sources, flows, and workbooks, the display name of the item that the job is related to.</run>
      </formatted-text>
    </desc>
  </column>
  <column caption='Item Type' datatype='string' name='[Item Name (copy)_1166713787202101253]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [jobLuid]:&#13;&#10;    MAX(&#13;&#10;        IFNULL(&#13;&#10;            CASE&#13;&#10;                LOWER(&#13;&#10;                    IFNULL(&#13;&#10;                        [objType], &#13;&#10;                        [Calculation_1396678843169206273]&#13;&#10;                    )&#13;&#10;                )&#13;&#10;                WHEN &apos;datasource&apos; THEN &apos;Datasource&apos;&#13;&#10;                WHEN &apos;flow&apos; THEN &apos;Flow&apos;&#13;&#10;                WHEN &apos;publishedconnection&apos; THEN &apos;PublishedConnection&apos;&#13;&#10;                WHEN &apos;workbook&apos; THEN &apos;Workbook&apos;&#13;&#10;            END,&#13;&#10;            (IF CONTAINS(LOWER([jobType]), &apos;flow&apos;) THEN &apos;Flow&apos; ELSE NULL END) // assume a Flow if the job is running one&#13;&#10;        )&#13;&#10;    )&#13;&#10;}' />
    <desc>
      <formatted-text>
        <run>For data sources, flows, and workbooks, the display name of the item that the job is related to.</run>
      </formatted-text>
    </desc>
  </column>
  <column caption='Item Owner Username' datatype='string' name='[Item Owner Luid (copy)_1166713787206901773]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [jobLuid]:&#13;&#10;    MAX([objOwnerName])&#13;&#10;}' />
    <desc>
      <formatted-text>
        <run>Username of the item owner.</run>
      </formatted-text>
    </desc>
  </column>
  <column caption='Parent Project Name' datatype='string' name='[Item Type (copy)_1166713787203604486]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [jobLuid]:&#13;&#10;    MAX(&#13;&#10;       [projectName]&#13;&#10;    )&#13;&#10;}' />
    <desc>
      <formatted-text>
        <run>The name of this item’s Parent Project.</run>
      </formatted-text>
    </desc>
  </column>
  <column caption='Item Owner Luid' datatype='string' name='[Item Type (copy)_1166713787205185547]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [jobLuid]:&#13;&#10;    MAX([objOwnerLuid])&#13;&#10;}' />
    <desc>
      <formatted-text>
        <run>LUID of the item owner.</run>
      </formatted-text>
    </desc>
  </column>
  <column caption='Item Content URL' datatype='string' name='[Item Type (copy)_1166713787205713932]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [jobLuid]:&#13;&#10;    MAX([objRepositoryUrl])&#13;&#10;}' />
    <desc>
      <formatted-text>
        <run>The content URL of the item, which represents a web-safe representation of the item name.</run>
      </formatted-text>
    </desc>
  </column>
  <column caption='Job Created At' datatype='datetime' name='[Job Completed At (copy)_1763159319825977345]' role='dimension' type='ordinal'>
    <calculation class='tableau' formula='{ FIXED [Calculation_1166713788613742607]:&#13;&#10;&#13;&#10;    MIN( IF [Is Last Job Record (copy)_1763159319825780736] THEN [eventTime] ELSE NULL END )&#13;&#10;&#13;&#10;}' />
  </column>
  <column caption='Job Started At' datatype='datetime' default-format='*m/d/yyyy hh:nn:ss:000' name='[Job Created Time (copy)_1867023573836746757]' role='dimension' type='ordinal'>
    <calculation class='tableau' formula='{ FIXED [Calculation_1166713788613742607]:&#13;&#10;&#13;&#10;MIN( IF CONTAINS(LOWER([eventState]), &apos;started&apos;) THEN [eventTime] ELSE NULL END)&#13;&#10;&#13;&#10;}' />
  </column>
  <column caption='Job Total Duration (s)' datatype='integer' name='[Job Execution Duration (s) (copy)_1867023574719111179]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='DATEDIFF(&#13;&#10;    &apos;second&apos;, &#13;&#10;    [Job Completed At (copy)_1763159319825977345],&#13;&#10;&#13;&#10;    // ideal: job is complete, duration is known.&#13;&#10;        // if not complete, NOW() with max of last known dataset date&#13;&#10;    IFNULL([Job Started At (copy)_1867023573837135878], [Calculation_1763159319831965698])&#13;&#10;)' />
  </column>
  <column caption='Job Execution Duration (s)' datatype='integer' name='[Job Queued Duration (s) (copy)_1867023574715740170]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='IFNULL(&#13;&#10;    DATEDIFF(&#13;&#10;        &apos;second&apos;, &#13;&#10;        [Job Created Time (copy)_1867023573836746757], &#13;&#10;        IFNULL([Job Started At (copy)_1867023573837135878], [Calculation_1763159319831965698]) // if the job hasn&apos;t completed, use the duration so far&#13;&#10;                                            // This will result in very long durations without data.&#13;&#10;                                            // Once data arrives, it will be pared back to reality&#13;&#10;    ),&#13;&#10;    0&#13;&#10;)' />
  </column>
  <column caption='Job Completed At' datatype='datetime' name='[Job Started At (copy)_1867023573837135878]' role='dimension' type='ordinal'>
    <calculation class='tableau' formula='{ FIXED [Calculation_1166713788613742607]:&#13;&#10;&#13;&#10;MAX(&#13;&#10;    IF &#13;&#10;        CONTAINS(LOWER([eventState]), &apos;succe&apos;) OR&#13;&#10;        CONTAINS(LOWER([eventState]), &apos;fail&apos;) OR&#13;&#10;        CONTAINS(LOWER([eventState]), &apos;cancel&apos;)&#13;&#10;            THEN [eventTime]&#13;&#10;        ELSE NULL&#13;&#10;        END&#13;&#10;)&#13;&#10;&#13;&#10;}' />
  </column>
  <column caption='Job Total Duration (d)' datatype='real' name='[Job Total Duration (s) (copy)_1867023574722187276]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='([Job Execution Duration (s) (copy)_1867023574719111179] / 86400.0)' />
  </column>
  <column caption='Error Message' datatype='string' name='[Last Job State (copy)_2288391620448075780]' role='dimension' semantic-role='' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [Calculation_1166713788613742607]:&#13;&#10;&#13;&#10;MAX(IF [Event State (copy) (copy)_1867023574713860105] AND [Event State (copy)_2288391620445376515] = &apos;Failed&apos; THEN [notes] ELSE NULL END)&#13;&#10;&#13;&#10;}' />
  </column>
  <column caption='Obj Name (impute from args)' datatype='string' name='[Obj Type (impute from args) (copy)_1166713787198435329]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='IF ISNULL([objName]) AND NOT ISNULL([args]) &#13;&#10;THEN&#13;&#10;    IF [jobType] = &apos;CreateExtracts&apos;&#13;&#10;            OR [jobType] = &apos;EncryptExtracts&apos;&#13;&#10;            OR [jobType] = &apos;EnqueueDataAlerts&apos;&#13;&#10;            OR [jobType] = &apos;MaterializeViews&apos;&#13;&#10;            OR [jobType] = &apos;RefreshExtracts&apos;&#13;&#10;    THEN REPLACE(&#13;&#10;                    SPLIT([args], &apos;,&apos;,3),&#13;&#10;            &apos;[&apos;,&#13;&#10;            &apos;&apos;&#13;&#10;         )       &#13;&#10;    ELSEIF [jobType] = &apos;ExtractServiceFullRefreshExtractTask&apos;&#13;&#10;        THEN REPLACE(&#13;&#10;                        SPLIT([args], &apos;,&apos;,2),&#13;&#10;                &apos;[&apos;,&#13;&#10;                &apos;&apos;&#13;&#10;             )        &#13;&#10;    ELSE NULL&#13;&#10;    END&#13;&#10;ELSE NULL&#13;&#10;END' />
  </column>
  <column caption='Parent Project LUID' datatype='string' name='[Parent Project Name (copy)_1166713787203829767]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [jobLuid]:&#13;&#10;    MAX(&#13;&#10;       [projectLuid]&#13;&#10;    )&#13;&#10;}' />
    <desc>
      <formatted-text>
        <run>The LUID of this item’s Parent Project.</run>
      </formatted-text>
    </desc>
  </column>
  <column caption='Parent Project Owner LUID' datatype='string' name='[Parent Project Owner Email (copy)_1166713787204497417]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='{ FIXED [jobLuid]:&#13;&#10;    MAX(&#13;&#10;       [projectOwnerLuid]&#13;&#10;    )&#13;&#10;}' />
    <desc>
      <formatted-text>
        <run>Theuser LUID of the owner of the parent project (if any) that the item exists within.</run>
      </formatted-text>
    </desc>
  </column>
